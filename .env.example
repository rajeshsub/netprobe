# Base URL for GitHub Pages deployment (e.g. /netprobe/ for github.com/user/netprobe)
VITE_BASE_URL=/netprobe/

# M-Lab locate API endpoint
VITE_LOCATE_API_URL=https://locate.measurementlab.net/v2/nearest/ndt/ndt7

# App identification sent to M-Lab
VITE_CLIENT_NAME=netprobe
VITE_CLIENT_VERSION=1.0.0

# Regional latency probe hosts (Linode/Akamai public speedtest servers)
VITE_REGION_US_EAST=speedtest.newark.linode.com
VITE_REGION_US_WEST=speedtest.fremont.linode.com
VITE_REGION_EU_WEST=speedtest.london.linode.com
VITE_REGION_ASIA_EAST=speedtest.tokyo2.linode.com
VITE_REGION_OCEANIA=speedtest.sydney.linode.com
