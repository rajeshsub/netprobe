# Base URL for GitHub Pages deployment (e.g. /echometer/ for github.com/user/echometer)
VITE_BASE_URL=/echometer/

# M-Lab locate API endpoint
VITE_LOCATE_API_URL=https://locate.measurementlab.net/v2/nearest/ndt/ndt7

# App identification sent to M-Lab
VITE_CLIENT_NAME=echometer
VITE_CLIENT_VERSION=1.0.0

# Fixed global region servers (M-Lab hostnames)
VITE_REGION_US_EAST=mlab1-lga05.mlab-oti.measurement-lab.org
VITE_REGION_US_WEST=mlab1-lax05.mlab-oti.measurement-lab.org
VITE_REGION_EU_WEST=mlab1-lhr05.mlab-oti.measurement-lab.org
VITE_REGION_ASIA_EAST=mlab1-nrt05.mlab-oti.measurement-lab.org
VITE_REGION_OCEANIA=mlab1-syd05.mlab-oti.measurement-lab.org
